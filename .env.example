# Gasless ProofDrop runs in safe mock mode by default.
PROOFDROP_MODE=mock
PROOFDROP_PORT=4177
# Keep 127.0.0.1 for local runs. Container deployments may set this to 0.0.0.0
# behind a reverse proxy.
PROOFDROP_HOST=127.0.0.1

# Default mock policy metadata used by the frontend and backend.
PROOFDROP_PACKAGE_ID=0xPROOFDROP_PACKAGE
PROOFDROP_MODULE_NAME=proofdrop_badge
PROOFDROP_FUNCTION_NAME=claim_proof_badge
PROOFDROP_MAX_GAS_BUDGET=50000000
PROOFDROP_EXPLORER_BASE_URL=https://explorer.iota.org/txblock/{digest}?network=testnet

# Ephemeral server-side demo signer. Session creation is safe in mock mode.
# Live sponsored demo execution remains disabled unless explicitly enabled.
PROOFDROP_DEMO_SIGNER_ENABLED=false
PROOFDROP_DEMO_SIGNER_TTL_SECS=600
PROOFDROP_DEMO_SIGNER_MAX_ACTIVE=100
PROOFDROP_DEMO_SIGNER_MAX_CREATES_PER_DAY=500
PROOFDROP_DEMO_SIGNER_MAX_EXECUTES_PER_DAY=100
IOTA_RPC_URL=https://api.testnet.iota.cafe

# Live testnet mode is opt-in only. Leave these placeholders for public hosting.
# Set PROOFDROP_MODE=live only on a trusted server with operator-owned testnet credentials.
GASKIT_GATEWAY_URL=replace-with-live-gaskit-gateway-url
GASKIT_PROOFDROP_APP_KEY=replace-with-server-side-proofdrop-app-key
GASKIT_SDK_MODULE=@iota-gaskit/sdk
